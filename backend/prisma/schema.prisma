generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                String   @id @default(uuid())
  provider          String   // 'github' | 'gitlab'
  repoId            String   @map("repo_id")
  name              String
  description       String?
  url               String
  stars             Int      @default(0)
  techStack         String[] @map("tech_stack")
  featured          Boolean  @default(false)
  showOnPortfolio   Boolean  @default(false) @map("show_on_portfolio")
  lastCommitAt      DateTime? @map("last_commit_at")
  syncedAt          DateTime @default(now()) @map("synced_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([provider, repoId])
  @@index([showOnPortfolio, featured])
  @@map("projects")
}
